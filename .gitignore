# Data — never commit the large CATCH slides or generated patches
data/raw/*
data/interim/*
data/processed/*
!data/**/.gitkeep

# Outputs (keep folders, ignore generated artefacts)
outputs/figures/*
outputs/logs/*
# trained model weights (.pt) — too large for git
outputs/checkpoints/*
# TensorBoard event logs
outputs/tensorboard/*
!outputs/**/.gitkeep

# Python
__pycache__/
*.py[cod]
.ipynb_checkpoints/
.venv/
venv/
env/

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/
