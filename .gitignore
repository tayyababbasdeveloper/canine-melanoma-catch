# =====================================================================
# Data
# We DO commit the generated demo patches + manifests under data/processed/
# so results are reproducible after a git pull. We never commit the large raw
# whole-slide images or interim files (real CATCH slides can be GBs).
# =====================================================================
data/raw/*
data/interim/*
!data/**/.gitkeep
# Keep the real-data FOLDER STRUCTURE visible (subtype folders + where-data-goes
# notes + the annotations README), but never the large slides/annotation blobs.
!data/raw/Melanoma/
!data/raw/Mast Cell Tumor/
!data/raw/SCC/
!data/raw/PNST/
!data/raw/Trichoblastoma/
!data/raw/Histiocytoma/
!data/raw/Plasmacytoma/
!data/raw/annotations/
!data/raw/**/PUT_SLIDES_HERE.txt
!data/raw/annotations/README.md
# but DO ignore the big real annotation files (re-downloadable, >100 MB)
data/raw/annotations/*.json
data/raw/annotations/*.sqlite
data/raw/annotations/*.zip

# =====================================================================
# Outputs
# These ARE committed (figures, logs, checkpoints, TensorBoard) so a git pull
# on another machine gives the *identical* results, models and predictions.
# Large model weights (*.pt) are stored via Git LFS — see .gitattributes.
# (Nothing under outputs/ is ignored.)
# =====================================================================

# Python
__pycache__/
*.py[cod]
.ipynb_checkpoints/
.venv/
venv/
env/

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/

# Archives (e.g. manual transfer zips)
*.zip
